# ------------------------------------------------------------
# 4) Funções da curva do coletor
# ------------------------------------------------------------
make_incidence_day <- function(df, all_dates) {
  df %>%
    filter(Data %in% all_dates) %>%
    distinct(Data, Espécie) %>%
    mutate(pres = 1) %>%
    pivot_wider(names_from = Espécie, values_from = pres, values_fill = 0) %>%
    right_join(tibble(Data = all_dates), by = "Data") %>%
    arrange(Data) %>%
    replace(is.na(.), 0) %>%
    select(-Data) %>%
    as.data.frame()
}

mao_tau <- function(X, n_perm = 1000) {
  sac <- vegan::specaccum(X, method = "random", permutations = n_perm)
  tibble(
    dia = seq_along(sac$sites),
    riqueza_media = sac$richness,
    sd = sac$sd,
    limite_inf = pmax(0, sac$richness - sac$sd),
    limite_sup = sac$richness + sac$sd
  )
}

# ------------------------------------------------------------
# 5) Curvas: geral + fitofisionomias
# ------------------------------------------------------------
grupos <- c("Fazenda Bananal", sort(unique(dat2$Fitofisionomia)))

curvas <- bind_rows(lapply(grupos, function(g) {
  df_g <- if (g == "Fazenda Bananal") dat2 else filter(dat2, Fitofisionomia == g)
  X <- make_incidence_day(df_g, sampling_dates)
  mao_tau(X, n_perm = 1000) %>% mutate(Grupo = g)
}))

write_csv(curvas, file.path(output_dir, "Curvas_Coletor_Geral_e_Fitofisionomias.csv"))

