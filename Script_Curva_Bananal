cols <- c(
  "Fazenda Bananal" = "black",
  "Agrofloresta" = "forestgreen",
  "Floresta alterada" = "orange3",
  "Floresta madura" = "blue3"
)

cols <- cols[grupos]
cols[is.na(cols)] <- "gray40"

xmax <- max(curvas$dia, na.rm = TRUE)
ymax <- max(curvas$limite_sup, na.rm = TRUE)

draw_collector_curve <- function() {
  plot(
    NA,
    xlim = c(1, xmax),
    ylim = c(0, ymax),
    xlab = "Dias de amostragem acumulados",
    ylab = "Riqueza acumulada de espécies",
    main = "Curva do coletor – Fazenda Bananal e fitofisionomias"
  )
  
  for (g in grupos) {
    df <- curvas %>% filter(Grupo == g)
    cor <- cols[g]
    
    polygon(
      c(df$dia, rev(df$dia)),
      c(df$limite_inf, rev(df$limite_sup)),
      col = adjustcolor(cor, alpha.f = 0.18),
      border = NA
    )
    
    lines(df$dia, df$riqueza_media, col = cor, lwd = 3)
  }
  
  legend("topleft", legend = grupos, col = cols[grupos], lwd = 3, bty = "n")
}

