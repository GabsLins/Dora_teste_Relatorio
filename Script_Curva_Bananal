stopifnot(all(c("Data", "Espécie", "Vegetação") %in% names(dat)))

# ------------------------------------------------------------
# 2) Limpeza dos dados
# ------------------------------------------------------------
dat2 <- dat %>%
  mutate(
    Data = dmy(str_squish(as.character(Data))),
    Espécie = str_squish(as.character(`Espécie`)),
    Vegetação = str_squish(as.character(`Vegetação`))
  ) %>%
  filter(
    !is.na(Data),
    !is.na(Espécie),
    Espécie != "",
    Espécie != "-",
    !is.na(Vegetação),
    Vegetação != "",
    Vegetação != "-"
  ) %>%
  mutate(
    Veget_norm = str_to_lower(Vegetação),
    Fitofisionomia = case_when(
      str_detect(Veget_norm, "agro") ~ "Agrofloresta",
      str_detect(Veget_norm, "alter") ~ "Floresta alterada",
      str_detect(Veget_norm, "madur") ~ "Floresta madura",
      TRUE ~ Vegetação
    )
  )

# Filtrar apenas Fazenda Bananal, se existir coluna Local
if ("Local" %in% names(dat2)) {
  dat2 <- dat2 %>%
    mutate(Local_norm = str_to_lower(str_squish(as.character(Local)))) %>%
    filter(str_detect(Local_norm, "fazenda bananal"))
}

dat2 <- dat2 %>%
  select(Data, Espécie, Fitofisionomia)

if (nrow(dat2) == 0) {
