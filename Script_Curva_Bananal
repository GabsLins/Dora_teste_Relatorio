abund_form <- dat2 %>%
  count(Fitofisionomia, Espécie, name = "n") %>%
  pivot_wider(names_from = Espécie, values_from = n, values_fill = 0)

abund_geral <- dat2 %>%
  count(Espécie, name = "n") %>%
  pivot_wider(names_from = Espécie, values_from = n, values_fill = 0)

calc_metrics <- function(mat, grupo) {
  riqueza <- specnumber(mat)
  abundancia <- rowSums(mat)
  shannon <- diversity(mat, index = "shannon")
  simpson <- diversity(mat, index = "simpson")
  pielou <- ifelse(riqueza > 1, shannon / log(riqueza), NA)
  
  tibble(
    Grupo = grupo,
    Riqueza = riqueza,
    Abundancia = abundancia,
    Shannon = shannon,
    Simpson = simpson,
    Pielou = pielou
  )
}

div_geral <- calc_metrics(abund_geral, "Fazenda Bananal")

div_form <- calc_metrics(
  abund_form %>% select(-Fitofisionomia),
  abund_form$Fitofisionomia
)

div_all <- bind_rows(div_geral, div_form)

write_csv(div_all, file.path(output_dir, "Indices_Biodiversidade.csv"))

