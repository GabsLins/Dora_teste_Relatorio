# ------------------------------------------------------------
# 8) Similaridade
# ------------------------------------------------------------
pa_form <- abund_form
pa_form[, -1] <- (pa_form[, -1] > 0) * 1

sim_jacc <- 1 - as.matrix(
  vegdist(select(pa_form, -Fitofisionomia), method = "jaccard", binary = TRUE)
)

rownames(sim_jacc) <- pa_form$Fitofisionomia
colnames(sim_jacc) <- pa_form$Fitofisionomia

sim_bray <- 1 - as.matrix(
  vegdist(select(abund_form, -Fitofisionomia), method = "bray")
)

rownames(sim_bray) <- abund_form$Fitofisionomia
colnames(sim_bray) <- abund_form$Fitofisionomia

write.csv(sim_jacc, file.path(output_dir, "Similaridade_Jaccard.csv"))
write.csv(sim_bray, file.path(output_dir, "Similaridade_BrayCurtis.csv"))

# ------------------------------------------------------------
# 9) Histograma de abundância relativa
# ------------------------------------------------------------
abund_sf <- dat2 %>%
  count(Espécie, Fitofisionomia, name = "n")

tot_species <- abund_sf %>%
  group_by(Espécie) %>%
  summarise(n_total = sum(n), .groups = "drop") %>%
  arrange(desc(n_total))

grand_total <- sum(tot_species$n_total)

plot_df <- abund_sf %>%
  left_join(tot_species, by = "Espécie") %>%
  mutate(
    rel_segment = n / grand_total,
    Espécie = factor(Espécie, levels = tot_species$Espécie)
  )

p_hist <- ggplot(plot_df, aes(x = Espécie, y = rel_segment, fill = Fitofisionomia)) +
  geom_col(width = 0.85) +
  scale_y_continuous(labels = percent_format(accuracy = 0.1)) +
  labs(
    title = "Abundância relativa geral e por fitofisionomia",
    x = "Espécies",
    y = "Abundância relativa",
    fill = "Fitofisionomia"
  ) +
  theme_bw() +
  theme(
    axis.text.x = element_text(angle = 60, hjust = 1, vjust = 1, face = "italic"),
    plot.title = element_text(hjust = 0.5)
  )

ggsave(
  file.path(output_dir, "Histograma_Abundancia_Relativa_Especies.png"),
  p_hist,
  width = 14,
  height = 8,
  dpi = 300
)

